{
  "name": "waybetter-calendar",
  "productName": "WayBetter Calendar",
  "version": "1.0.0",
  "description": "A slim macOS desktop calendar app.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --mac --dir",
    "dist": "npm run build && electron-builder --mac",
    "dist:mac": "npm run build && electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "prepare:release-env": "node scripts/write-release-env.mjs",
    "install:local": "node scripts/install-local.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "calendar",
    "electron",
    "agenda"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "build": {
    "appId": "com.waybetter.calendar",
    "productName": "WayBetter Calendar",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "artifactName": "WayBetter-Calendar-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "resources/**/*",
      "!resources/**/*.psd",
      "!resources/**/.DS_Store",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/waybetter-calendar-icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/waybetter-calendar-icon.png",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "category": "Office",
      "icon": "resources/waybetter-calendar-icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "bootstrap-icons": "^1.13.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-icons": "^16.22.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  }
}
