WAYBETTER_GOOGLE_CLIENT_ID=
# Optional for Google clients that require it.
WAYBETTER_GOOGLE_CLIENT_SECRET=

WAYBETTER_MICROSOFT_CLIENT_ID=
# Optional, useful because Microsoft redirect URLs are easiest to register exactly.
# Register http://localhost:53685/oauth/microsoft/callback in your Entra app.
WAYBETTER_MICROSOFT_REDIRECT_PORT=53685

# Optional video meeting providers.
WAYBETTER_ZOOM_CLIENT_ID=
WAYBETTER_ZOOM_CLIENT_SECRET=
# Optional, useful because Zoom redirect URLs are usually exact.
# Register http://localhost:53683/oauth/zoom/callback in Zoom Marketplace.
WAYBETTER_ZOOM_REDIRECT_PORT=53683

# Used only for creating standalone Teams meeting links.
WAYBETTER_TEAMS_CLIENT_ID=
# Optional, useful because Teams redirect URLs are easiest to register exactly.
# Register http://localhost:53684/oauth/teams/callback as a public client/native redirect URI in Azure.
WAYBETTER_TEAMS_REDIRECT_PORT=53684
